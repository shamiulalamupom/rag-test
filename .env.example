# Database
DATABASE_URL=postgres://rag:rag@localhost:5432/ragdb

# Ollama
OLLAMA_URL=http://localhost:11434

# Embedding
EMBED_MODEL=rjmalagon/gte-qwen2-1.5b-instruct-embed-f16
EMBED_DIM=1536

# Chat
CHAT_MODEL=llama3.1

# Debugging
DEBUG_RAG=true

# Phase 4: Hybrid Retrieval
RETRIEVE_VEC_K=40           # Top K from vector search
RETRIEVE_FTS_K=40           # Top K from FTS search
RETRIEVE_FINAL_K=12         # Final chunks after fusion
RRF_K=60                    # RRF constant (Reciprocal Rank Fusion)
MAX_CHUNKS_PER_PAGE=2       # Diversity: max per page
MAX_CHUNKS_PER_HEADING=2    # Diversity: max per heading

# Phase 5: Reranking
RERANK_ENABLED=true         # Enable reranker
RERANK_CANDIDATES=50        # Candidates to rerank
RERANK_TOP_K=12             # Final after reranking
RERANK_THRESHOLD=4          # Min relevance score (0-10)

# Phase 8: Performance Hardening
OLLAMA_TIMEOUT_MS=60000     # Fetch timeout
OLLAMA_RETRIES=2            # Max retries on failure
